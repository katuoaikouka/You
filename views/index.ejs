<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>仙人Tube Next</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { background-color: #fff; }
        .search-input { border: 1px solid #dfe1e5; transition: box-shadow 0.2s; }
        .search-input:focus { box-shadow: 0 1px 6px rgba(32,33,36,0.28); outline: none; border-color: rgba(0,0,0,0); }
    </style>
</head>
<body class="flex flex-col h-screen">
    <header class="p-4 flex justify-end">
        <button id="openSettings" class="text-gray-600 hover:bg-gray-100 p-2 rounded-full">⚙️</button>
    </header>

    <main class="flex-grow flex flex-col justify-center items-center px-4">
        <div class="mb-8 flex items-center gap-2">
            <svg viewBox="0 0 24 24" class="w-10 h-10 text-red-600 fill-current"><path d="M23.5 6.2c-.2-1.1-.9-1.9-1.9-2.1C19.9 3.7 12 3.7 12 3.7s-7.9 0-9.6.4C1.3 4.3.6 5.1.4 6.2.1 8 .1 12 .1 12s0 4 .3 5.8c.2 1.1.9 1.9 1.9 2.1 1.7.4 9.6.4 9.6.4s7.9 0 9.6-.4c1.1-.2 1.7-.9 1.9-2.1.3-1.8.3-5.8.3-5.8s0-4-.3-5.8zm-13.9 9.3V8.5l6.2 3.5-6.2 3.5z"></path></svg>
            <h1 class="text-3xl font-bold">仙人Tube <span class="text-gray-400 font-light">Next</span></h1>
        </div>

        <form action="/search" method="get" id="searchForm" class="w-full max-w-[580px] relative">
            <input type="text" name="q" id="searchbox" placeholder="キーワード、またはURLを入力..." 
                   class="search-input w-full py-3 px-6 rounded-full text-lg">
            <div class="mt-8 flex justify-center gap-3">
                <button type="submit" class="bg-gray-50 border border-gray-100 px-6 py-2 rounded text-sm hover:border-gray-300">動画検索</button>
            </div>
        </form>
    </main>

    <div id="settingsPanel" class="fixed inset-0 bg-black/50 hidden flex justify-center items-center z-50">
        <div class="bg-white p-6 rounded-xl max-w-sm w-full">
            <h2 class="text-xl font-bold mb-4">再生設定</h2>
            <select id="modeSelect" class="w-full p-2 border rounded mb-4">
                <option value="normal">通常ストリーミング</option>
                <option value="embed">公式埋め込みモード</option>
            </select>
            <button id="saveBtn" class="w-full bg-blue-600 text-white py-2 rounded">保存して閉じる</button>
        </div>
    </div>

    <script>
        const form = document.getElementById('searchForm');
        form.addEventListener('submit', (e) => {
            const query = document.getElementById('searchbox').value;
            const ytRegex = /(?:https?:\/\/)?(?:www\.)?youtu(?:\.be\/|be\.com\/(?:watch\?v=|embed\/|v\/|shorts\/))([\w\-]+)/;
            const match = query.match(ytRegex);
            if (match) {
                e.preventDefault();
                window.location.href = `/w/${match[1]}`;
            }
        });

        // 設定ロジック
        const panel = document.getElementById('settingsPanel');
        document.getElementById('openSettings').onclick = () => panel.classList.remove('hidden');
        document.getElementById('saveBtn').onclick = () => {
            const mode = document.getElementById('modeSelect').value;
            document.cookie = `playbackMode=${mode}; path=/; max-age=31536000`;
            panel.classList.add('hidden');
        };
    </script>
</body>
</html>
