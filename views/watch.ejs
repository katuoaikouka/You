<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= video.title %> - 仙人Tube</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-white">
    <header class="p-3 border-b mb-4">
        <a href="/" class="text-xl font-bold text-red-600">仙人Tube</a>
    </header>

    <main class="max-w-5xl mx-auto px-4">
        <div class="aspect-video bg-black rounded-xl overflow-hidden shadow-2xl">
            <% if (playbackMode === 'embed') { %>
                <iframe src="https://www.youtube.com/embed/<%= video.videoId %>" class="w-full h-full" frameborder="0" allowfullscreen></iframe>
            <% } else { %>
                <video controls autoplay class="w-full h-full">
                    <source src="<%= video.formatStreams[0]?.url %>" type="video/mp4">
                    ブラウザが動画再生に対応していません。
                </video>
            <% } %>
        </div>

        <h1 class="text-xl font-bold mt-4"><%= video.title %></h1>
        
        <div class="mt-4 flex items-center gap-3 py-2 border-b">
            <div class="w-10 h-10 bg-gray-200 rounded-full"></div>
            <div>
                <p class="font-bold text-sm"><%= video.author %></p>
                <p class="text-xs text-gray-500"><%= video.subCountText %></p>
            </div>
        </div>

        <div class="bg-gray-100 p-4 rounded-xl mt-4 text-sm whitespace-pre-wrap">
            <p class="font-bold mb-2"><%= video.viewCountText %> • <%= video.publishedText %></p>
            <%= video.description %>
        </div>
    </main>
</body>
</html>
