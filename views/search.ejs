<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= query %> - 仙人Tube</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-[#f9f9f9]">
    <header class="bg-white p-3 border-b sticky top-0 z-50 flex items-center gap-4">
        <a href="/" class="flex-shrink-0 ml-2">
            <svg viewBox="0 0 24 24" class="w-7 h-7 text-red-600 fill-current"><path d="M23.5 6.2c-.2-1.1-.9-1.9-1.9-2.1C19.9 3.7 12 3.7 12 3.7s-7.9 0-9.6.4C1.3 4.3.6 5.1.4 6.2.1 8 .1 12 .1 12s0 4 .3 5.8c.2 1.1.9 1.9 1.9 2.1 1.7.4 9.6.4 9.6.4s7.9 0 9.6-.4c1.1-.2 1.7-.9 1.9-2.1.3-1.8.3-5.8.3-5.8s0-4-.3-5.8zm-13.9 9.3V8.5l6.2 3.5-6.2 3.5z"></path></svg>
        </a>
        <form action="/search" class="flex-grow max-w-2xl flex items-center">
            <input type="text" name="q" value="<%= query %>" class="w-full border rounded-l-full py-1.5 px-4 outline-none focus:border-blue-500">
            <button class="bg-gray-100 border border-l-0 rounded-r-full px-5 py-1.5 hover:bg-gray-200">🔍</button>
        </form>
    </header>

    <main class="max-w-6xl mx-auto p-4">
        <div class="flex flex-col gap-4">
            <% results.forEach(video => { %>
                <div class="flex flex-col md:flex-row gap-4 cursor-pointer hover:bg-gray-100 p-2 rounded-xl transition" onclick="location.href='/w/<%= video.videoId %>'">
                    <div class="relative flex-shrink-0 w-full md:w-72 lg:w-80">
                        <img src="<%= video.videoThumbnails[0].url %>" class="w-full aspect-video object-cover rounded-xl">
                        <span class="absolute bottom-2 right-2 bg-black/80 text-white text-xs px-1 rounded"><%= video.lengthText %></span>
                    </div>
                    <div>
                        <h3 class="font-bold text-lg line-clamp-2"><%= video.title %></h3>
                        <p class="text-sm text-gray-600 mt-1"><%= video.author %> • <%= video.viewCountText %> • <%= video.publishedText %></p>
                        <p class="text-xs text-gray-500 mt-2 line-clamp-2"><%= video.descriptionSnippet %></p>
                    </div>
                </div>
            <% }); %>
        </div>

        <div class="flex justify-center py-10">
            <a href="/search?q=<%= query %>&p=<%= page + 1 %>" class="px-8 py-2 border rounded-full font-bold bg-white hover:bg-gray-50">さらに読み込む</a>
        </div>
    </main>
</body>
</html>
